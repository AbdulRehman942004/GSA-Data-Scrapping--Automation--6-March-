POSTGRESQL_HOST=localhost
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=your_db_name
POSTGRESQL_USERNAME=your_postgresql_username
POSTGRESQL_PASSWORD=your_postgresql_password

# Proxy list: ip:port:user:pass (comma-separated)
# Each worker gets its own proxy → own IP → true parallel scraping
SCRAPE_PROXIES=ip1:port1:user1:pass1,ip2:port2:user2:pass2